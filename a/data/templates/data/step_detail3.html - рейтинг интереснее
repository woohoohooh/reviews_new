{% extends "data/base.html" %}
{% block title %}{{ step.title }}{% endblock %}
{% block description %}{{ step.seo_description }}{% endblock %}
{% block keywords %}{{ step.keywords }}{% endblock %}
{% load blog_extras %}
{% block extra_head %}
<script type="application/ld+json">
    {{ schema_data|safe|json_script:"application/ld+json" }}
</script>
<script type="application/ld+json">
    {{ schema_breadcrumbs|safe|json_script:"application/ld+json" }}
</script>
{% endblock %}
{% block content %}
<style>
    .top-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 30px 40px;
        border-radius: 12px;
        margin: 20px 0 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px 30px;
    }
    .top-header h1 {
        margin: 0;
        font-size: 2.8rem;
        font-weight: 800;
    }
    .top-header .subtitle {
        font-size: 1.5rem;
        opacity: 0.95;
    }
    .top-header .rating-simple {
        text-align: right;
        font-size: 1.4rem;
    }
    .top-header .rating-simple .stars {
        font-size: 2.2rem;
        margin-bottom: 4px;
    }
    .chips-header {
        text-align: center;
        margin: 50px 0 30px;
    }
    .chips-header h2 {
        margin: 0 0 10px 0;
        font-size: 2rem;
    }
    .chips-header p {
        color: #666;
        font-size: 1rem;
    }
    .chips-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin: 0;
        padding: 0;
        background: none;
    }
    .pros-item, .cons-item {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 20px 25px;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.12);
        transition: all 0.3s ease;
    }
    .pros-item {
        background: #e8f5e8;
        border-left: 6px solid #28a745;
    }
    .cons-item {
        background: #ffe6e6;
        border-left: 6px solid #dc3545;
    }
    .pros-item:hover, .cons-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }
    .vote-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: none;
        background: rgba(255,255,255,0.7);
        font-size: 1.4rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .vote-btn:hover {
        background: rgba(255,255,255,1);
        transform: scale(1.1);
    }
    .vote-count {
        font-weight: bold;
        font-size: 1.4rem;
        min-width: 36px;
        text-align: center;
    }
    .item-text {
        font-size: 1.15rem;
        font-weight: 600;
        flex: 1;
    }
    .filters {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 30px;
    }
    .filters button {
        padding: 10px 20px;
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 30px;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s;
    }
    .filters button.active, .filters button:hover {
        background: #667eea;
        color: white;
        border-color: #667eea;
    }
    .expert-sidebar {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 30px;
        height: fit-content;
        position: sticky;
        top: 20px;
        border: 1px solid #e0e0e0;
    }
    .expert-sidebar h3 {
        text-align: center;
        margin-bottom: 20px;
        color: #333;
    }
    .expert-recommend {
        text-align: center;
        font-size: 4.5rem;
        margin-top: 25px;
    }
    .page-footer-info {
        text-align: center;
        color: #777;
        margin: 60px 0 30px;
        font-size: 0.95rem;
    }
    .page-footer-info a {
        color: #667eea;
        text-decoration: underline;
    }
    @media (max-width: 768px) {
        .top-header {
            padding: 25px 20px;
            text-align: center;
        }
        .top-header .rating-simple {
            text-align: center;
        }
        .pros-item, .cons-item {
            padding: 16px 20px;
        }
    }
</style>

<div class="top-header">
    <div>
        <h1>1win</h1>
        <div class="subtitle">— отзывы о выплатах</div>
    </div>
    <div class="rating-simple">
        <div class="stars">★★★☆☆</div>
        <div><strong>3.8</strong> (на основе 247 отзывов)</div>
    </div>
</div>

{% if step.image %}
    <img src="{{ step.image.url }}" alt="{{ step.image_alt }}" style="border-radius: 12px; max-width: 100%; height: auto; margin-bottom: 40px;">
{% endif %}

<div class="chips-header">
    <h2>Плюсы и минусы 1win</h2>
    <p>На основе анализа тысяч отзывов из разных источников интернета</p>
</div>

<div class="chips-container">
    <div class="cons-item" data-id="con-1">
        <button class="vote-btn">+</button>
        <span class="item-text">Длительная верификация аккаунта</span>
        <span class="vote-count">32</span>
    </div>
    <div class="cons-item" data-id="con-2">
        <button class="vote-btn">+</button>
        <span class="item-text">Шаблонные ответы поддержки</span>
        <span class="vote-count">28</span>
    </div>
    <div class="pros-item" data-id="pro-1">
        <button class="vote-btn">+</button>
        <span class="item-text">Быстрые выплаты при успешной верификации</span>
        <span class="vote-count">24</span>
    </div>
    <div class="cons-item" data-id="con-3">
        <button class="vote-btn">+</button>
        <span class="item-text">Сложные условия отыгрыша бонусов</span>
        <span class="vote-count">22</span>
    </div>
    <div class="cons-item" data-id="con-4">
        <button class="vote-btn">+</button>
        <span class="item-text">Периодические блокировки сайта</span>
        <span class="vote-count">19</span>
    </div>
    <div class="pros-item" data-id="pro-2">
        <button class="vote-btn">+</button>
        <span class="item-text">Удобный интерфейс личного кабинета</span>
        <span class="vote-count">18</span>
    </div>
    <div class="pros-item" data-id="pro-3">
        <button class="vote-btn">+</button>
        <span class="item-text">Щедрая программа лояльности</span>
        <span class="vote-count">15</span>
    </div>
    <div class="pros-item" data-id="pro-4">
        <button class="vote-btn">+</button>
        <span class="item-text">Много способов вывода средств</span>
        <span class="vote-count">12</span>
    </div>
</div>

<div class="content-layout">
    <div>
        <h2 style="margin-bottom: 20px;">Отзывы о выплатах 1win</h2>

        <div class="filters">
            <button onclick="sortComments('positive')">Сначала положительные</button>
            <button onclick="sortComments('negative')">Сначала отрицательные</button>
            <button onclick="sortComments('newest')">Сначала новые</button>
            <button onclick="sortComments('rating')">С высоким рейтингом</button>
        </div>

        <div class="comments-section">
            {% if comments %}
                <ul id="comments-list">
                    {% for comment in comments %}
                        <li class="comment-item {% if comment.is_positive %}positive{% else %}negative{% endif %}"
                            style="border-left: 5px solid {% if comment.is_positive %}#28a745{% else %}#dc3545{% endif %};"
                            data-timestamp="{{ comment.created_date|date:'U' }}">
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <strong>{{ comment.username|default:"Аноним" }}</strong>
                                {% if comment.created_date %}
                                    <span style="font-size: 0.9em; color: #888;">{{ comment.formatted_created_date }}</span>
                                {% endif %}
                            </div>
                            <p>{{ comment.text|linebreaks }}</p>
                            <span style="font-size: 0.9em; font-weight: bold; color: {% if comment.is_positive %}#28a745{% else %}#dc3545{% endif %};">
                                {% if comment.is_positive %}Позитивный{% else %}Негативный{% endif %}
                            </span>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p id="no-comments">Комментариев пока нет.</p>
            {% endif %}
        </div>
    </div>

    <div class="expert-sidebar">
        <h3>Мнение эксперта</h3>
        <p>Основная проблема — длительная верификация (до 7 дней). После неё выплаты быстрые (от 1 часа до 2 дней). Поддержка работает, но шаблонно. Бонусы щедрые, но вейджер высокий. Подходит опытным игрокам, новичкам лучше начинать с малых сумм.</p>
        <div class="expert-recommend">👌</div>
    </div>
</div>

<div class="page-footer-info">
    Последнее обновление: {{ step.formatted_updated_date }} | <a href="#">Редактировать информацию о компании</a>
</div>

<form method="post" class="comment-form">
    {% csrf_token %}
    <div style="display: none;">
        <label for="honey_pot">Оставьте это поле пустым</label>
        <input type="text" name="honey_pot" id="honey_pot">
    </div>
    {% if not user.is_authenticated %}
    <div>
        <input type="text" name="user_name" id="user_name" placeholder="Ваше имя" required>
    </div>
    {% endif %}
    <textarea name="content" rows="3" placeholder="Оставьте комментарий..." required></textarea>
    <button type="submit">Отправить</button>
</form>

<script>
    // Voting
    document.addEventListener('DOMContentLoaded', function() {
        const voteButtons = document.querySelectorAll('.vote-btn');
        voteButtons.forEach(button => {
            button.addEventListener('click', function(e) {
                e.preventDefault();
                const item = this.closest('.pros-item, .cons-item');
                const count = item.querySelector('.vote-count');
                const current = parseInt(count.textContent);
                const isPros = item.classList.contains('pros-item');
                this.style.background = isPros ? '#28a745' : '#dc3545';
                this.style.color = 'white';
                this.textContent = '✓';
                count.textContent = current + 1;
                this.disabled = true;
            });
        });
    });

    // Сортировка отзывов (клиентская для демо)
    function sortComments(type) {
        const list = document.getElementById('comments-list');
        const items = Array.from(list.querySelectorAll('li'));

        items.sort((a, b) => {
            if (type === 'positive') {
                const aPos = a.classList.contains('positive') ? -1 : 1;
                const bPos = b.classList.contains('positive') ? -1 : 1;
                return aPos - bPos;
            } else if (type === 'negative') {
                const aNeg = a.classList.contains('negative') ? -1 : 1;
                const bNeg = b.classList.contains('negative') ? -1 : 1;
                return aNeg - bNeg;
            } else if (type === 'newest') {
                return b.dataset.timestamp - a.dataset.timestamp;
            }
            return 0;
        });

        items.forEach(item => list.appendChild(item));

        // подсветка активной кнопки
        document.querySelectorAll('.filters button').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
    }
</script>
{% endblock %}